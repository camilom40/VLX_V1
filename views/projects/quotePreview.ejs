<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quote · <%= project.projectName %></title>
  <%- include('../partials/_head.ejs') %>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
  <%- include('_quotePreviewStyles') %>
  </style>
</head>
<body>
  <div class="quote-shell">
    <%- include('_quotePreviewMain') %>
    <div class="no-print mt-6 flex flex-wrap justify-center gap-3">
      <button type="button" onclick="window.print()" class="inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
        Print
      </button>
      <a id="downloadPdfLink" href="/projects/<%= project._id %>/quote-pdf?unit=inches" class="inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-md hover:bg-indigo-700">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
        Download PDF
      </a>
    </div>
  </div>

  <script>
    function renderWindowPreviews() {
      document.querySelectorAll('.window-preview-mini').forEach(preview => {
        const raw = preview.getAttribute('data-panel-config') || '%7B%7D';
        let panelConfigStr;
        try {
          panelConfigStr = decodeURIComponent(raw);
        } catch (e) {
          panelConfigStr = '{}';
        }
        try {
          const panelConfig = JSON.parse(panelConfigStr);
          preview.innerHTML = '';
          const frame = document.createElement('div');
          frame.className = 'aluminum-frame';
          const panelContainer = document.createElement('div');
          panelContainer.className = 'panel-container';
          panelContainer.style.flexDirection = panelConfig.orientation === 'vertical' ? 'column' : 'row';
          const panels = panelConfig.panels || ['O'];
          const ratios = panelConfig.panelRatios || panels.map(() => 1);
          panels.forEach((panel, index) => {
            const isOperable = panel === 'X';
            const ratio = ratios[index] || 1;
            const panelDiv = document.createElement('div');
            panelDiv.className = 'panel-glass' + (isOperable ? ' operable-glass' : '');
            panelDiv.style.flex = ratio + ' 0 0%';
            const label = document.createElement('div');
            label.className = 'panel-label';
            label.textContent = panel;
            panelDiv.appendChild(label);
            panelContainer.appendChild(panelDiv);
            if (index < panels.length - 1 && panelConfig.hasMullion) {
              const mullion = document.createElement('div');
              mullion.className = 'mullion ' + (panelConfig.orientation === 'vertical' ? 'vertical' : 'horizontal');
              panelContainer.appendChild(mullion);
            }
          });
          frame.appendChild(panelContainer);
          preview.appendChild(frame);
        } catch (e) {
          preview.innerHTML = '<div class="aluminum-frame" style="display:flex;align-items:center;justify-content:center;height:100%;"><div class="panel-glass" style="width:100%;height:100%;"><div class="panel-label" style="font-size:10px;">Window</div></div></div>';
        }
      });
    }

    function inchesToMm(inches) { return inches * 25.4; }

    function updateDimensionsFromGlobal() {
      const unit = window.globalPreferences?.unit || 'inches';
      document.querySelectorAll('.dimension-display').forEach(display => {
        const widthInches = parseFloat(display.dataset.widthInches);
        const heightInches = parseFloat(display.dataset.heightInches);
        const isMobile = display.dataset.mobile === 'true';
        if (isNaN(widthInches) || isNaN(heightInches)) return;
        if (isMobile) {
          if (unit === 'inches') {
            display.innerHTML = `${widthInches.toFixed(2)} × ${heightInches.toFixed(2)} <span class="dimension-unit">in</span>`;
          } else {
            const widthMm = inchesToMm(widthInches);
            const heightMm = inchesToMm(heightInches);
            display.innerHTML = `${Math.round(widthMm)} × ${Math.round(heightMm)} <span class="dimension-unit">mm</span>`;
          }
          return;
        }
        const allSpans = Array.from(display.children);
        let widthSpan = null;
        let heightSpan = null;
        allSpans.forEach(span => {
          if (span.textContent && span.textContent.trim().startsWith('Width:')) widthSpan = span;
          else if (span.textContent && span.textContent.trim().startsWith('Height:')) heightSpan = span;
        });
        if (unit === 'inches') {
          if (widthSpan) {
            widthSpan.innerHTML = `Width: ${widthInches.toFixed(2)} <span class="dimension-unit">in</span>`;
          }
          if (heightSpan) {
            heightSpan.innerHTML = `Height: ${heightInches.toFixed(2)} <span class="dimension-unit">in</span>`;
          }
        } else {
          const widthMm = inchesToMm(widthInches);
          const heightMm = inchesToMm(heightInches);
          if (widthSpan) {
            widthSpan.innerHTML = `Width: ${Math.round(widthMm)} <span class="dimension-unit">mm</span>`;
          }
          if (heightSpan) {
            heightSpan.innerHTML = `Height: ${Math.round(heightMm)} <span class="dimension-unit">mm</span>`;
          }
        }
      });
      const downloadLink = document.getElementById('downloadPdfLink');
      if (downloadLink) {
        const m = downloadLink.href.match(/\/projects\/([^/]+)\/quote-pdf/);
        if (m) downloadLink.href = '/projects/' + m[1] + '/quote-pdf?unit=' + unit;
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      renderWindowPreviews();
      updateDimensionsFromGlobal();
      window.addEventListener('unitChanged', updateDimensionsFromGlobal);
    });
  </script>
</body>
</html>
